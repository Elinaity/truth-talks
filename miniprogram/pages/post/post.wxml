<view class="container">
  <!-- 占位填充块 -->
  <view class="navbar-placeholder"></view>

  <!-- 自定义导航栏 -->
  <navbar title="{{currentCategoryName}}" showPicker="{{showCategoryPicker}}" bind:arrowTap="toggleCategoryPicker" />

  <!-- 弹窗遮罩 -->
  <view class="picker-overlay" wx:if="{{showCategoryPicker}}" bindtap="toggleCategoryPicker">
    <view class="picker-modal" catch:tap="preventTap">
      <view class="picker-title">选择话题</view>
      <view
        class="picker-item {{item.key === category ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="key"
        bindtap="onSelectCategory"
        data-key="{{item.key}}"
      >{{item.name}}</view>
    </view>
  </view>

  <!-- 发布表单 -->
  <view class="post-form">
    <textarea
      class="input-textarea"
      placeholder="说点什么...（限500字）"
      maxlength="500"
      bindinput="onInput"
      value="{{content}}"
    ></textarea>

    <view class="char-count">
      <text class="{{charCount > 480 ? 'warning' : ''}}">{{charCount}}</text>/500
    </view>

    <view class="hint-box">
      <text class="hint-icon">⚠️</text>
      <text class="hint-text">每天可发布 </text>
      <text class="hint-highlight">5</text>
      <text class="hint-text"> 次</text>
      <view class="hint-divider"></view>
      <text class="hint-text">今日已用：</text>
      <text class="hint-highlight">{{usedCount}}</text>
      <text class="hint-text"> 次</text>
    </view>

    <button
      class="btn-primary {{canPost ? '' : 'disabled'}}"
      bindtap="onSubmit"
      disabled="{{!canPost}}"
    >发布</button>
  </view>
</view>
