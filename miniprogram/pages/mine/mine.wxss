.container {
  min-height: 100vh;
  background: #F7F5F2;
}

.nav-bar {
  height: 56px;
  background: #6b5b95;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 18px;
  font-weight: 500;
  position: relative;
}

.nav-icon {
  position: absolute;
  left: 20px;
  font-size: 20px;
}

.user-header {
  background: #6B5B95;
  padding: 30px 20px;
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.user-avatar {
  width: 64px;
  height: 64px;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  margin-bottom: 12px;
  align-self: center;
}

.user-id {
  text-align: center;
  font-size: 16px;
  font-weight: 500;
  margin-bottom: 8px;
}

.level-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  background: rgba(255,255,255,0.2);
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 13px;
  margin-bottom: 12px;
}

.level-icon {
  font-size: 14px;
}

.level-name {
  font-weight: 500;
}

.exp-info {
  font-size: 11px;
  opacity: 0.8;
  margin-bottom: 16px;
}

.exp-text {
  display: block;
  text-align: center;
  margin-bottom: 6px;
}

.exp-bar {
  width: 160px;
  height: 4px;
  background: rgba(255,255,255,0.3);
  border-radius: 2px;
  margin: 0 auto 6px;
  overflow: hidden;
}

.exp-progress {
  height: 100%;
  background: #FFE066;
  border-radius: 2px;
  transition: width 0.3s;
}

.exp-hint {
  display: block;
  text-align: center;
}

.exp-max {
  display: block;
  text-align: center;
  color: #FFE066;
}

.user-stats {
  display: flex;
  justify-content: center;
  gap: 24px;
}

.stat-item {
  text-align: center;
}

.stat-num {
  font-size: 20px;
  font-weight: 600;
}

.stat-label {
  font-size: 11px;
  opacity: 0.7;
  margin-top: 2px;
}

.card {
  margin: 16px;
  background: #fff;
  border-radius: 16px;
  padding: 20px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}

.card-title {
  font-size: 14px;
  color: #2D2D2D;
  font-weight: 500;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.card-icon {
  font-size: 16px;
}

.remain-count {
  font-size: 24px;
  color: #6B5B95;
  font-weight: 600;
}

.remain-label {
  font-size: 12px;
  color: #888;
  margin-top: 4px;
}

.reset-hint {
  font-size: 11px;
  color: #ccc;
  margin-top: 8px;
}

.rules-list {
  font-size: 13px;
  color: #666;
  line-height: 1.8;
}

.rule-item {
  margin-bottom: 4px;
}

/* 我的帖子 */
.my-posts-section {
  margin: 0 16px 16px;
}

.section-title {
  font-size: 15px;
  font-weight: 500;
  color: #2D2D2D;
  margin-bottom: 12px;
}

.posts-list {
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}

.post-item {
  padding: 14px 16px;
  border-bottom: 1px solid #f0f0f0;
}

.post-item:last-child {
  border-bottom: none;
}

.post-content {
  font-size: 14px;
  color: #2D2D2D;
  line-height: 1.5;
  margin-bottom: 8px;
  /* 单行截断 */
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.post-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 11px;
  color: #888;
}

.post-stats {
  display: flex;
  gap: 12px;
}

.empty-posts {
  padding: 30px;
  text-align: center;
  color: #888;
  font-size: 13px;
}

.loading {
  padding: 20px;
  text-align: center;
  color: #888;
  font-size: 13px;
}
