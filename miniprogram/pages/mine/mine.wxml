<view class="container">
  <!-- 用户信息头部 -->
  <view class="user-header">
    <view class="user-avatar">🙂</view>
    <view class="user-id">{{anonymousId}}</view>

    <!-- 等级信息 -->
    <view class="level-badge" wx:if="{{levelInfo}}">
      <text class="level-icon">{{levelInfo.icon}}</text>
      <text class="level-name">Lv.{{levelInfo.level}} {{levelInfo.name}}</text>
    </view>
    <view class="exp-info" wx:if="{{expProgress}}">
      <text class="exp-text">经验 {{expProgress.current.minExp}} / {{expProgress.next ? expProgress.next.minExp : expProgress.current.minExp}}</text>
      <view class="exp-bar" wx:if="{{expProgress.next}}">
        <view class="exp-progress" style="width: {{expProgress.progress}}%"></view>
      </view>
      <text class="exp-hint" wx:if="{{expProgress.next}}">再攒 {{expProgress.expToNext}} 经验升级</text>
      <text class="exp-max" wx:if="{{!expProgress.next}}">已满级</text>
    </view>

    <view class="user-stats">
      <view class="stat-item">
        <view class="stat-num">{{stats.posts}}</view>
        <view class="stat-label">发布</view>
      </view>
      <view class="stat-item">
        <view class="stat-num">{{stats.comments}}</view>
        <view class="stat-label">评论</view>
      </view>
      <view class="stat-item">
        <view class="stat-num">{{stats.likes}}</view>
        <view class="stat-label">获赞</view>
      </view>
    </view>
  </view>

  <!-- 今日数据卡片 -->
  <view class="card">
    <view class="card-title">
      <text class="card-icon">📊</text>
      <text>今日数据</text>
    </view>
    <view class="remain-count">{{remainCount}}</view>
    <view class="remain-label">剩余发布次数</view>
    <view class="reset-hint">⚠️ 次日 0 点重置</view>
  </view>

  <!-- 规则卡片 -->
  <view class="card">
    <view class="card-title">
      <text class="card-icon">📋</text>
      <text>发布规则</text>
    </view>
    <view class="rules-list">
      <view class="rule-item">• 每天可发布 5 条真心话</view>
      <view class="rule-item">• 每条内容最多 500 字</view>
      <view class="rule-item">• 禁止人身攻击、违法内容</view>
      <view class="rule-item">• 保护隐私，禁止泄露他人信息</view>
    </view>
  </view>

  <!-- 我的帖子 -->
  <view class="my-posts-section">
    <view class="section-title">我的帖子</view>
    <view class="loading" wx:if="{{loadingPosts}}">
      <text>加载中...</text>
    </view>
    <view class="posts-list" wx:if="{{!loadingPosts}}">
      <view 
        class="post-item" 
        wx:for="{{myPosts}}" 
        wx:key="_id"
        bindtap="goToDetail"
        data-id="{{item._id}}"
      >
        <view class="post-content">{{item.content}}</view>
        <view class="post-meta">
          <text class="post-time">{{item.timeAgo}}</text>
          <view class="post-stats">
            <text>🤍 {{item.likes}}</text>
            <text>💬 {{item.commentCount}}</text>
          </view>
        </view>
      </view>
      <view class="empty-posts" wx:if="{{myPosts.length === 0}}">
        <text>还没有发布过帖子</text>
      </view>
    </view>
  </view>
</view>
