.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F7F5F2;
}

/* 右侧下拉按钮 - 位于原生导航栏右侧 */
.nav-dropdown {
  position: fixed;
  top: 0;
  right: 8px;
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 101;
}

.nav-dropdown-arrow {
  font-size: 10px;
  color: rgba(255,255,255,0.85);
  transition: transform 0.2s;
}

.nav-dropdown-arrow.up {
  transform: rotate(180deg);
}

.feed {
  flex: 1;
  padding: 12px;
  box-sizing: border-box;
}

.picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-modal {
  background: #fff;
  border-radius: 16px;
  width: 280px;
  max-height: 80vh;
  overflow-y: auto;
  padding: 8px 0 20px;
}

.picker-title {
  text-align: center;
  font-size: 14px;
  color: #999;
  padding: 12px 20px 16px;
  border-bottom: 1px solid #f0f0f0;
  margin-bottom: 6px;
}

.picker-item {
  padding: 14px 24px;
  font-size: 15px;
  color: #333;
  display: flex;
  align-items: center;
  cursor: pointer;
}

.picker-item.active {
  color: #6B5B95;
  font-weight: 500;
}

.card {
  background: #fff;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}

.card-content {
  font-size: 15px;
  color: #2D2D2D;
  line-height: 1.6;
  margin-bottom: 12px;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #888;
  font-size: 12px;
}

.card-actions {
  display: flex;
  gap: 16px;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 4px;
}

.action-icon {
  font-size: 14px;
}

.action-count {
  font-size: 12px;
}

.time-text {
  color: #888;
  font-size: 12px;
}

.loading, .no-more, .empty {
  text-align: center;
  padding: 20px;
  color: #888;
  font-size: 13px;
}

.empty-hint {
  display: block;
  margin-top: 8px;
  color: #ccc;
  font-size: 12px;
}
