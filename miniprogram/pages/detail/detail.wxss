.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F7F5F2;
}

.nav-bar {
  height: 56px;
  background: #6B5B95;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 18px;
  font-weight: 500;
  position: relative;
}

.nav-back {
  position: absolute;
  left: 20px;
  font-size: 20px;
}

.content {
  flex: 1;
  overflow-y: auto;
}

.post-card {
  background: #fff;
  padding: 16px;
  margin-bottom: 8px;
}

.post-content {
  font-size: 16px;
  color: #2D2D2D;
  line-height: 1.7;
  margin-bottom: 12px;
}

.post-meta {
  font-size: 12px;
  color: #888;
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid #f0f0f0;
}

.meta-divider {
  color: #ddd;
}

.post-stats {
  display: flex;
  gap: 20px;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 14px;
  color: #2D2D2D;
}

.stat-icon {
  font-size: 16px;
}

.comments-section {
  padding: 0 16px;
}

.comments-title {
  font-size: 13px;
  color: #888;
  padding: 12px 0;
  border-bottom: 1px solid #eee;
}

.comments-list {
  padding-bottom: 80px;
}

.comment-item {
  padding: 12px 0;
  border-bottom: 1px solid #f5f5f5;
}

.comment-user {
  font-size: 12px;
  color: #6B5B95;
  font-weight: 500;
  margin-bottom: 4px;
}

.comment-text {
  font-size: 14px;
  color: #2D2D2D;
  line-height: 1.5;
}

.comment-time {
  font-size: 11px;
  color: #ccc;
  margin-top: 4px;
}

.no-comments {
  text-align: center;
  padding: 30px;
  color: #888;
  font-size: 13px;
}

.no-comments .hint {
  display: block;
  margin-top: 8px;
  color: #ccc;
  font-size: 12px;
}

.comment-input-wrap {
  padding: 12px 16px;
  background: #fff;
  border-top: 1px solid #eee;
  display: flex;
  gap: 8px;
  align-items: center;
}

.comment-input {
  flex: 1;
  background: #f5f5f5;
  border: none;
  border-radius: 20px;
  padding: 10px 16px;
  font-size: 14px;
  outline: none;
}

.comment-send {
  color: #6B5B95;
  font-size: 14px;
  font-weight: 500;
}
