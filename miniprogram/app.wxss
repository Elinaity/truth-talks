/* 全局样式 */
page {
  background-color: #F7F5F2;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 14px;
  color: #2D2D2D;
  line-height: 1.6;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}

/* 按钮样式 */
.btn-primary {
  background: #6B5B95;
  color: #fff;
  border: none;
  border-radius: 24px;
  height: 48px;
  font-size: 16px;
  font-weight: 500;
  letter-spacing: 2px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary[disabled] {
  background: #ccc;
}

.btn-primary:active {
  opacity: 0.8;
}

/* 输入框 */
.input-textarea {
  background: #fff;
  border-radius: 16px;
  padding: 16px;
  font-size: 15px;
  color: #2D2D2D;
  line-height: 1.6;
  border: none;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  width: 100%;
  min-height: 200px;
  box-sizing: border-box;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 2px 8px;
  background: rgba(107, 91, 149, 0.1);
  color: #6B5B95;
  border-radius: 4px;
  font-size: 12px;
}

/* 分割线 */
.divider {
  height: 1px;
  background: #eee;
  margin: 12px 0;
}

/* 提示框 */
.hint-box {
  background: #fff3e0;
  padding: 10px 12px;
  border-radius: 8px;
  font-size: 12px;
  color: #888;
}
